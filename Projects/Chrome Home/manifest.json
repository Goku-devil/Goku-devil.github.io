{
  "manifest_version": 3,
  "version": "1.1.2",
  "name": "Custom Chrome Home",
  "description": "A custom Chrome start page with your background image and useful shortcuts.",
  "host_permissions": [
    "https://suggestqueries.google.com/*",
    "https://www.google.com/*"
  ],
  "icons":{
    "128" : "asserts/Chrome.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}